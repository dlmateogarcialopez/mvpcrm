# ============================================
# Máquina de Ventas — Variables de Entorno
# Copia este archivo como .env y completa los valores
# ============================================

# --- Entorno ---
NODE_ENV=development

# --- Base de Datos (MySQL) ---
DB_NAME=maquina_ventas
DB_USER=mv_user
DB_PASSWORD=mv_password
DB_ROOT_PASSWORD=root_password
DB_PORT=3307
DATABASE_URL=mysql://mv_user:mv_password@localhost:3307/maquina_ventas

# --- Aplicación ---
APP_PORT=3000
PORT=3000

# --- Autenticación OAuth ---
OAUTH_SERVER_URL=http://localhost:3001
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=http://localhost:3001
BUILT_IN_FORGE_API_KEY=

# --- Telegram (Alertas) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=notificaciones@tu-dominio.com

# --- Google Calendar (Sincronización) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Webhooks (Facebook/ManyChat) ---
WEBHOOK_SECRET=

# --- SMS (Twilio, opcional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
